# Özel .env konumu (yol; proje kökü yerine). Boşsa sırayla aranır: kök/.env → web/.env → çalışma dizini/.env
# BLS_DOTENV_PATH=

# Panel FastAPI tabanı (run_login_step varsayılanı: http://127.0.0.1:8000)
# BLS_API_BASE=http://127.0.0.1:8000

# Proxy atanmamis profillerde bile proxy isteniyorsa: 1
# BLS_REQUIRE_PROXY=0

# Login ekrani
BLS_LOGIN_URL=https://turkey.blsspainglobal.com/Global/Account/LogIn?ReturnUrl=%2FGlobal%2Fappointment%2Fnewappointment

# page.goto zaman aşımı (ms) — net::ERR_TIMED_OUT alıyorsanız artırın (default: 60000)
# BLS_GOTO_TIMEOUT_MS=60000
# net::ERR_* hatalarında kaç kez yeniden denensin (default: 2)
# BLS_GOTO_RETRY_MAX=2

# LoginStep: captcha + Dogrula sonrasi round-trip poll (ms), 5000-120000
BLS_POST_VERIFY_CAPTCHA_POLL_MS=15000
# Dogrula sonrasi poll bos kalirsa en fazla kac kez cookie/reload (1-10)
BLS_CAPTCHA_VERIFY_STUCK_MAX=2

# Geliştirme modunda OCR tüm denemelerden sonra terminalde input() ile bekler.
# Üretimde 0 bırakın; geliştirme/debug sırasında 1 yapın.
# BLS_MANUAL_CAPTCHA_FALLBACK=0

# =========================
# CAPTCHA ÇÖZÜMÜ — Yerel OCR (ddddocr + Tesseract fallback)
# Kurulum: sudo apt-get install tesseract-ocr tesseract-ocr-tur
# pip install pytesseract
# =========================
# TESSERACT_CMD=   # özel binary yolu (yoksa PATH'ten aranır)
# BLS_SKIP_CAPTCHA=0
# OCR eşleşme adedi beklenen bantın dışındaysa tıklama yok → visual_break (varsayılan 1–12)
# BLS_CAPTCHA_MATCH_COUNT_MIN=1
# BLS_CAPTCHA_MATCH_COUNT_MAX=12
# Hibrit_güvensiz karoların oranı bu eşikten fazlaysa tıklama yok (0.0–1.0)
# BLS_CAPTCHA_UNCERTAINTY_MAX_FRACTION=0.65
# OCR boş çıktı: solve içinden .btn-refresh en fazla bu kadar (varsayılan 3)
# BLS_CAPTCHA_BLANK_REFRESH_MAX=3
# Bulanık eşleşme: tam eşleşme yoksa Levenshtein ≤ N adaylar; en yüksek skorlu K karo
# BLS_CAPTCHA_FUZZY_MAX_EDIT=1
# BLS_CAPTCHA_FUZZY_TOP_K=3
# Ön işleme: unsharp + adaptif eşik (0=kapalı)
# BLS_CAPTCHA_PREPROCESS_SHARPEN=1
# BLS_CAPTCHA_THRESH_ADAPTIVE=1
# BLS_CAPTCHA_ADAPTIVE_BLOCK=31
# BLS_CAPTCHA_ADAPTIVE_C=-5
# BLS_CAPTCHA_DDDD_UPSCALE=2
# Kalıcı bellek: başarılı turda OCR==hedef zorunlu (1=eski davranış)
# BLS_CAPTCHA_MEMORY_STRICT_OCR=0

# Poll edilecek randevu sayfasi/endpoint'i
BLS_APPOINTMENT_CHECK_URL=https://turkey.blsspainglobal.com/Global/appointment/newappointment

# Manuel login icin tarayicida beklenecek maksimum sure
MANUAL_LOGIN_TIMEOUT_SEC=300

# Request loop
REQUEST_TIMEOUT=30
POLL_INTERVAL_SEC=20
CARD_NUMBER=4543123456789012
EXPIRY_DATE=12/28
CVV=123

# =========================
# KISISEL TEST VERILERI
# =========================
TEST_AD_SOYAD=emre camcı
TEST_EMAIL=shockemre@gmail.com
TEST_TELEFON=05061483405

# =========================
# GMAIL OTP (IMAP, docs/README_GMAIL_OTP.md)
# =========================
GMAIL_IMAP_USER=ornek@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
GMAIL_OTP_TIMEOUT_SEC=120
GMAIL_OTP_POLL_INTERVAL_SEC=5
# Konu/gonderende ara (virgulle ayirilir)
GMAIL_OTP_FILTER_SUBSTRINGS=vfs,bls

# =========================
# Playwright TS — captcha eğitim verisi (web/tests/fixtures.ts)
# Varsayılan çıktı: {repo}/dataset/raw_captchas/
# =========================
# BLS_CAPTCHA_DATASET_DIR=/absolute/path/raw_captchas
# BLS_CAPTCHA_DATASET_AUTOWATCH=1
# Python ile hizalı selektörler (isteğe bağlı override)
# BLS_CAPTCHA_CONTAINER=.captcha-wrapper
# BLS_CAPTCHA_TILE_SELECTOR=img.captcha-img
# Tesseract.js güven eşikleri (0–100); fuzzy için daha yüksek kullanılır
# BLS_CAPTCHA_MIN_CONFIDENCE=38
# BLS_CAPTCHA_FUZZY_MIN_CONFIDENCE=52
# src yetersizse karo PNG screenshot (device pixel ratio) + preprocess (1=açık)
# BLS_CAPTCHA_TILE_JPEG_FALLBACK=1
# =========================
# Playwright TS — BLS LoginFlow beklemeleri ve hata PNG (dataset/failures/)
# =========================
# BLS_LOGIN_STABILIZE_BUDGET_MS=38000   # stabilizeNavigationThenLoginAnchors üst süre
# BLS_STEP0_VERIFY_TIMEOUT_MS=90000     # doğrula/submit görünür bekleme
# BLS_EMAIL_PRE_STABILIZE_MS=12000      # eposta öncesi captcha/ag stabilizasyonu
